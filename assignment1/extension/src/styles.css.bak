:root {
  color-scheme: dark;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif;
  --bg: #0a0e27;
  --bg-soft: #131829;
  --card: rgba(15, 23, 42, 0.8);
  --card-border: rgba(148, 163, 184, 0.12);
  --text: #f1f5f9;
  --text-secondary: #cbd5e1;
  --muted: #94a3b8;
  --accent: #06b6d4;
  --accent-hover: #00d4ff;
  --success: #10b981;
  --danger: #ef4444;
}

* {
  box-sizing: border-box;
}

html,
body,
#root {
  margin: 0;
  min-width: 420px;
  min-height: 100vh;
  background: var(--bg);
}

body {
  background:
    radial-gradient(circle at 20% 50%, rgba(6, 182, 212, 0.08), transparent 40%),
    radial-gradient(circle at 80% 80%, rgba(34, 197, 94, 0.05), transparent 40%),
    linear-gradient(135deg, var(--bg) 0%, var(--bg-soft) 100%);
  color: var(--text);
  line-height: 1.6;
}

a {
  color: var(--accent);
  text-decoration: none;
  transition: color 200ms ease;
}

a:hover {
  color: var(--accent-hover);
}

.shell {
  padding: 16px;
  max-width: 100%;
}

/* Header & Hero */
.hero {
  border: 1px solid var(--card-border);
  background: linear-gradient(135deg, rgba(15, 23, 42, 0.9) 0%, rgba(30, 41, 59, 0.8) 100%);
  backdrop-filter: blur(20px);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  border-radius: 16px;
  padding: 20px;
  animation: slideDown 400ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.hero-content {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
}

.hero-actions {
  display: flex;
  gap: 8px;
  align-items: center;
}

.eyebrow {
  margin: 0 0 8px;
  color: var(--accent);
  text-transform: uppercase;
  letter-spacing: 0.12em;
  font-size: 0.7rem;
  font-weight: 700;
}

h1,
h2,
h3,
h4,
p {
  margin-top: 0;
}

h1 {
  font-size: 1.3rem;
  line-height: 1.2;
  margin-bottom: 4px;
  background: linear-gradient(135deg, var(--text), var(--text-secondary));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.subtitle {
  font-size: 0.85rem;
  color: var(--muted);
  margin-bottom: 0;
}

h2 {
  font-size: 1.05rem;
  margin-bottom: 8px;
}

h3 {
  font-size: 0.95rem;
  margin-bottom: 12px;
  color: var(--text);
}

h4 {
  font-size: 0.85rem;
  margin-bottom: 8px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--accent);
}

/* Buttons */
.primary,
.secondary,
.settings-btn,
.toggle-btn,
.close-btn,
.save-btn {
  border: 0;
  border-radius: 12px;
  padding: 11px 16px;
  font-weight: 600;
  cursor: pointer;
  transition: all 200ms ease;
  font-size: 0.9rem;
}

.primary {
  display: flex;
  align-items: center;
  gap: 8px;
  color: #020617;
  background: linear-gradient(135deg, var(--accent), #00d4ff);
  box-shadow: 0 4px 12px rgba(6, 182, 212, 0.3);
  white-space: nowrap;
}

.primary:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(6, 182, 212, 0.4);
}

.primary:disabled {
  cursor: wait;
  opacity: 0.7;
}

.button-icon {
  font-size: 1.1em;
}

.settings-btn {
  background: rgba(255, 255, 255, 0.06);
  color: var(--text);
  padding: 9px 12px;
  font-size: 1rem;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.settings-btn:hover {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.2);
}

.secondary,
.toggle-btn,
.close-btn {
  color: var(--text);
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.secondary:hover,
.toggle-btn:hover {
  background: rgba(255, 255, 255, 0.12);
  border-color: var(--accent);
}

.close-btn {
  padding: 6px 10px;
  font-size: 1rem;
}

.save-btn {
  width: 100%;
  background: linear-gradient(135deg, var(--accent), #00d4ff);
  color: #020617;
  margin-top: 12px;
}

.save-btn:hover {
  transform: translateY(-1px);
}

/* Card & Settings */
.card {
  border: 1px solid var(--card-border);
  background: var(--card);
  backdrop-filter: blur(16px);
  border-radius: 14px;
  padding: 16px;
  margin-top: 12px;
  animation: fadeIn 300ms ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.settings-card {
  animation: slideDown 300ms ease;
}

.settings-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.settings-header h3 {
  margin-bottom: 0;
}

.field-label {
  display: block;
  font-size: 0.75rem;
  color: var(--muted);
  margin-bottom: 8px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-weight: 600;
}

.input-group {
  display: flex;
  gap: 8px;
  margin-bottom: 12px;
}

input {
  flex: 1;
  min-width: 0;
  border: 1px solid rgba(255, 255, 255, 0.12);
  background: rgba(255, 255, 255, 0.04);
  color: var(--text);
  border-radius: 10px;
  padding: 10px 12px;
  font-size: 0.9rem;
  outline: none;
  transition: all 150ms ease;
}

input:focus {
  background: rgba(255, 255, 255, 0.08);
  border-color: var(--accent);
  box-shadow: 0 0 0 3px rgba(6, 182, 212, 0.1);
}

input::placeholder {
  color: #64748b;
}

.settings-info {
  font-size: 0.8rem;
  color: var(--muted);
  margin: 0;
}

/* Status Bar */
.status-bar {
  margin-top: 10px;
  min-height: 32px;
}

.status,
.error {
  margin: 0;
  font-size: 0.85rem;
  animation: slideIn 200ms ease;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateX(-8px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.status {
  color: var(--muted);
}

.error {
  color: var(--danger);
  font-weight: 500;
}

/* Insight Panel */
.insight-panel {
  animation: slideUp 400ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.slide-in {
  animation: slideUp 400ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

.insight-header {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  align-items: flex-start;
  margin-bottom: 14px;
  padding-bottom: 12px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.insight-title {
  flex: 1;
  min-width: 0;
}

.truncate {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.url-text {
  font-size: 0.8rem;
  color: var(--muted);
  margin: 4px 0 0;
}

.source-badge {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 6px 10px;
  border-radius: 20px;
  background: rgba(6, 182, 212, 0.1);
  border: 1px solid rgba(6, 182, 212, 0.3);
  font-size: 0.75rem;
  color: var(--accent);
  font-weight: 600;
  white-space: nowrap;
}

.badge-dot {
  display: inline-block;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  animation: pulse 2s infinite;
}

.badge-dot.gemini {
  background: var(--accent);
}

.badge-dot.fallback {
  background: var(--muted);
}

@keyframes pulse {
  0%,
  100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}

.metadata-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 16px;
}

.meta-pill {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 6px 10px;
  background: rgba(6, 182, 212, 0.1);
  border: 1px solid rgba(6, 182, 212, 0.2);
  border-radius: 20px;
  font-size: 0.8rem;
  color: var(--text-secondary);
}

.meta-icon {
  font-size: 0.9rem;
}

/* Content Grid */
.content-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
  margin-bottom: 16px;
}

.content-card {
  padding: 12px;
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.06);
  animation: fadeIn 400ms ease;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}

.card-icon {
  font-size: 1.2rem;
}

.bullet-list {
  margin: 0;
  padding: 0;
  list-style: none;
}

.bullet-item {
  margin: 0 0 8px;
  padding-left: 16px;
  position: relative;
  font-size: 0.9rem;
  line-height: 1.5;
  color: var(--text-secondary);
  animation: fadeIn 400ms ease;
  animation-delay: var(--delay, 0ms);
}

.bullet-item::before {
  content: '•';
  position: absolute;
  left: 0;
  color: var(--accent);
  font-weight: bold;
}

.bullet-item:last-child {
  margin-bottom: 0;
}

/* Links Section */
.links-section {
  margin-top: 16px;
  padding-top: 16px;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.link-count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  background: rgba(6, 182, 212, 0.2);
  border-radius: 50%;
  font-size: 0.75rem;
  color: var(--accent);
  font-weight: 600;
}

.link-groups {
  display: grid;
  gap: 10px;
}

.link-group {
  padding: 10px;
  border-radius: 10px;
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.06);
  animation: fadeIn 400ms ease;
  animation-delay: var(--delay, 0ms);
}

.category-name {
  margin-bottom: 8px;
}

.link-list {
  list-style: none;
  margin: 0;
  padding: 0;
}

.link-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 8px;
  padding: 7px 0;
  font-size: 0.85rem;
  border-bottom: 1px solid rgba(255, 255, 255, 0.04);
}

.link-item:last-child {
  border-bottom: none;
}

.link-text {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: var(--text-secondary);
}

.link-action {
  padding: 4px 8px;
  border-radius: 6px;
  background: rgba(6, 182, 212, 0.1);
  border: 1px solid rgba(6, 182, 212, 0.3);
  font-size: 0.75rem;
  color: var(--accent);
  white-space: nowrap;
  transition: all 150ms ease;
  cursor: pointer;
  font-weight: 600;
  text-decoration: none;
  display: inline-block;
}

.link-action:hover {
  background: rgba(6, 182, 212, 0.2);
  border-color: var(--accent-hover);
  color: var(--accent-hover);
  transform: translateX(2px);
}

.expand-more {
  margin-top: 8px;
  width: 100%;
  padding: 8px;
  background: rgba(6, 182, 212, 0.08);
  border: 1px solid rgba(6, 182, 212, 0.25);
  color: var(--accent);
  border-radius: 8px;
  font-size: 0.8rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 200ms ease;
  font-family: inherit;
}

.expand-more:hover {
  background: rgba(6, 182, 212, 0.15);
  border-color: var(--accent-hover);
  color: var(--accent-hover);
  transform: translateY(-1px);
}

/* Empty State */
.empty-state {
  text-align: center;
  padding: 40px 20px;
  animation: fadeIn 500ms ease;
}

.empty-icon {
  font-size: 3rem;
  margin-bottom: 12px;
  animation: bounce 1s infinite;
}

@keyframes bounce {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-4px);
  }
}

.empty-state h2 {
  margin-bottom: 8px;
  font-size: 1.2rem;
}

.empty-state p {
  color: var(--muted);
  margin: 0;
  font-size: 0.9rem;
}

/* Responsive */
@media (max-width: 500px) {
  .shell {
    padding: 12px;
  }

  .hero {
    padding: 16px;
  }

  .hero-content {
    flex-direction: column;
    gap: 12px;
  }

  .hero-actions {
    width: 100%;
  }

  .primary {
    flex: 1;
    justify-content: center;
  }

  h1 {
    font-size: 1.1rem;
  }

  .content-grid {
    grid-template-columns: 1fr;
  }

  .insight-header {
    flex-direction: column;
  }
}
